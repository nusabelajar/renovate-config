{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>kakushindev/renovate-config"
  ],
  "packageRules": [
    {
      "matchDatasources": [
        "npm"
      ],
      "matchPackageNames":["@nusabelajar"],
      "registryUrls": ["https://npm.pkg.github.com"]
    }
  ],
  "hostRules": [
    {
      "matchHost": "https://npm.pkg.github.com",
      "hostType": "npm",
      "token": "{{ secrets.MEND_GITHUB_PACKAGES_TOKEN }}"
    }
  ],
  "npmrc": "@nusabelajar:registry=https://npm.pkg.github.com"
}
